# ---- Auth (Keycloak resource server) + Catalogue ----
# Issuer MUST equal the browser-visible issuer and the catalogue's issuer, e.g.
# https://idp.uniche-eccch.eu/realms/uniche (prod) or the local dev issuer.
IDP_ISSUER_URI=https://idp.uniche-eccch.eu/realms/uniche
REQUIRED_AUDIENCE=uniche-platform
# Catalogue base URL (no /api/v1 suffix) — the authorization authority.
CATALOGUE_BASE_URL=http://uniche-catalogue.localhost:8080
# This tool's slug in the catalogue's authoring_tools registry.
TOOL_SLUG=media-editor

# ---- Database ----
# Async SQLAlchemy URL (asyncpg driver). Host "postgres" matches docker-compose.
DATABASE_URL=postgresql+asyncpg://uniche:uniche@postgres:5432/uniche

# ---- Redis (arq job queue) ----
REDIS_URL=redis://redis:6379/0

# ---- Storage ----
STORAGE_DIR=/data/storage
MAX_UPLOAD_SIZE_MB=200

# ---- Inference provider ----
# mock       -> deterministic offline output (default, no API keys needed)
# http       -> calls a configured hosted inference endpoint
# openrouter -> calls OpenRouter (currently only backs audio.tts, via /audio/speech)
INFERENCE_PROVIDER=mock
INFERENCE_BASE_URL=
INFERENCE_API_KEY=
INFERENCE_TIMEOUT_SECONDS=120

# Capability-specific endpoint paths (appended to INFERENCE_BASE_URL when provider=http)
INFERENCE_IMAGE_CAPTION_PATH=/image/caption
INFERENCE_AUDIO_TRANSCRIBE_PATH=/audio/transcribe

# ---- Conversational agent planner ----
# mock       -> deterministic rule-based planner (default, works offline)
# openrouter -> plan via an OpenRouter LLM
AGENT_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3.6-flash
AGENT_TIMEOUT_SECONDS=120
AGENT_MAX_REPAIR_RETRIES=2

# audio.tts (only used when INFERENCE_PROVIDER=openrouter; shares OPENROUTER_API_KEY/BASE_URL above)
# Voice names are model-specific and non-obvious: OpenAI-style names like
# "alloy"/"verse" 500 on this model -- it needs one of Google's native Gemini
# TTS voices (e.g. "Kore", "Puck").
OPENROUTER_TTS_MODEL=google/gemini-3.1-flash-tts-preview
OPENROUTER_TTS_VOICE=Kore
# "mp3" | "pcm" -- model-dependent; the default model above only accepts "pcm".
# "pcm" comes back headerless and gets wrapped in a WAV container using the
# sample rate below (confirmed 24kHz mono via the response's content-type
# header: "audio/pcm;rate=24000;channels=1").
OPENROUTER_TTS_RESPONSE_FORMAT=pcm
OPENROUTER_TTS_PCM_SAMPLE_RATE=24000
# Optional: sent as HTTP-Referer / X-Title on OpenRouter calls (site
# attribution for their public rankings; leave blank to omit both headers).
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# ---- Misc ----
LOG_LEVEL=INFO
# CORS: "*" allows any origin (dev). Or a comma-separated list, e.g.
# CORS_ALLOW_ORIGINS=http://localhost:5173,https://app.example.org
CORS_ALLOW_ORIGINS=*
