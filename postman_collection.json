              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/assets",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "assets"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('created', () => pm.response.to.have.status(201));",
                  "const id = pm.response.json().id;",
                  "pm.collectionVariables.set('video_asset_id', id);",
                  "console.log('video_asset_id =', id);"
                ]
              }
            }
          ]
        },
        {
          "name": "List Project Assets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/assets",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "assets"]
            }
          }
        },
        {
          "name": "Get Asset Metadata",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/assets/{{asset_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "assets", "{{asset_id}}"]
            }
          }
        },
        {
          "name": "Download Asset",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/assets/{{asset_id}}/download",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "assets", "{{asset_id}}", "download"]
            }
          }
        },
        {
          "name": "Delete Asset (soft)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/assets/{{asset_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "assets", "{{asset_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Capabilities",
      "item": [
        {
          "name": "List Capabilities",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/capabilities",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "capabilities"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('14 capabilities', () => pm.expect(pm.response.json().length).to.eql(14));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Capability (image.caption)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/capabilities/image.caption",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "capabilities", "image.caption"]
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create image.caption Job",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"capability_id\": \"image.caption\",\n  \"project_id\": \"{{project_id}}\",\n  \"asset_id\": \"{{asset_id}}\",\n  \"input\": {}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/jobs",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('created', () => pm.response.to.have.status(201));",
                  "const id = pm.response.json().id;",
                  "pm.collectionVariables.set('job_id', id);",
                  "console.log('job_id =', id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create audio.transcribe Job",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"capability_id\": \"audio.transcribe\",\n  \"project_id\": \"{{project_id}}\",\n  \"asset_id\": \"{{audio_asset_id}}\",\n  \"input\": {}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/jobs",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('job_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create not_implemented Job (image.upscale)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"capability_id\": \"image.upscale\",\n  \"project_id\": \"{{project_id}}\",\n  \"asset_id\": \"{{asset_id}}\",\n  \"input\": {}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/jobs",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('job_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create image.resize Job (tool → derived asset)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"capability_id\": \"image.resize\",\n  \"project_id\": \"{{project_id}}\",\n  \"asset_id\": \"{{asset_id}}\",\n  \"input\": { \"width\": 640, \"height\": 480 }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/jobs",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.collectionVariables.set('job_id', pm.response.json().id);"]
              }
            }
          ]
        },
        {
          "name": "Create video.thumbnail Job (tool → derived image)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"capability_id\": \"video.thumbnail\",\n  \"project_id\": \"{{project_id}}\",\n  \"asset_id\": \"{{video_asset_id}}\",\n  \"input\": { \"timestamp\": 1 }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/jobs",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.collectionVariables.set('job_id', pm.response.json().id);"]
              }
            }
          ]
        },
        {
          "name": "Create audio.trim Job (tool → derived audio)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"capability_id\": \"audio.trim\",\n  \"project_id\": \"{{project_id}}\",\n  \"asset_id\": \"{{audio_asset_id}}\",\n  \"input\": { \"start\": 0, \"end\": 5 }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/jobs",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.collectionVariables.set('job_id', pm.response.json().id);"]
              }
            }
          ]
        },
        {
          "name": "Get Job",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/{{job_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "{{job_id}}"]
            }
          }
        },
        {
          "name": "List Jobs for Project",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/jobs",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "jobs"]
            }
          }
        },
        {
          "name": "Job Events (SSE)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "text/event-stream" }],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/{{job_id}}/events",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "{{job_id}}", "events"]
            },
            "description": "Server-Sent Events stream of job status/progress until terminal. Note: standard Postman shows this as a single response once the stream closes; use the SSE/curl client for live streaming."
          }
        }
      ]
    }
  ]
}
