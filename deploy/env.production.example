# Copy this file to /opt/uniche-media-editor/.env on the VM, fill in the real
# values there, and run: chmod 600 /opt/uniche-media-editor/.env
# Never commit the completed file.

# PostgreSQL. URL-encode special characters in POSTGRES_PASSWORD when placing
# the same password in DATABASE_URL.
POSTGRES_DB=uniche
POSTGRES_USER=uniche
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
DATABASE_URL=postgresql+asyncpg://uniche:CHANGE_ME_URL_ENCODED@postgres:5432/uniche

REDIS_URL=redis://redis:6379/0
STORAGE_DIR=/data/storage
MAX_UPLOAD_SIZE_MB=200

# Keycloak resource server and remote UNICHE Catalogue.
IDP_ISSUER_URI=https://idp.uniche-eccch.eu/realms/uniche
REQUIRED_AUDIENCE=uniche-platform
CATALOGUE_BASE_URL=https://catalogue.uniche-eccch.eu
TOOL_SLUG=media-editor

# Replace this with the public frontend origin. Do not use "*" in production.
CORS_ALLOW_ORIGINS=https://media-editor.example.org
LOG_LEVEL=INFO

# Hosted inference. Leave secrets empty only when the corresponding provider is mock.
INFERENCE_PROVIDER=mock
INFERENCE_BASE_URL=
INFERENCE_API_KEY=
INFERENCE_TIMEOUT_SECONDS=120
INFERENCE_IMAGE_CAPTION_PATH=/image/caption
INFERENCE_AUDIO_TRANSCRIBE_PATH=/audio/transcribe

AGENT_PROVIDER=mock
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3.6-flash
AGENT_TIMEOUT_SECONDS=120
AGENT_MAX_REPAIR_RETRIES=2
OPENROUTER_TTS_MODEL=google/gemini-3.1-flash-tts-preview
OPENROUTER_TTS_VOICE=Kore
OPENROUTER_TTS_RESPONSE_FORMAT=pcm
OPENROUTER_TTS_PCM_SAMPLE_RATE=24000
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=
